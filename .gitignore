# --- Rust / Tauri backend ---
/src-tauri/target/
# Tauri-generated ACL / capability schemas — regenerated on every build.
/src-tauri/gen/schemas/
**/*.rs.bk
*.pdb

# --- Node / frontend ---
node_modules/
dist/
dist-ssr/
*.local
.vite/
# TypeScript incremental build cache (regenerated by `tsc -b`).
*.tsbuildinfo

# --- Test / coverage ---
coverage/
/src-tauri/coverage/
*.profraw
lcov.info

# --- Local app data (never commit) ---
settings.json.tmp

# --- OS / editor noise ---
.DS_Store
Thumbs.db
*.swp
.idea/

# --- Secrets / env (never commit) ---
.env
.env.*
!.env.example
.envrc.local
# Signing material must never be committed.
*.p12
*.cer
*.certSigningRequest
*.mobileprovision

# --- Local Claude Code overrides (shared settings.json IS committed) ---
.claude/settings.local.json
.claude/memory/*.bak-*
.claude/scheduled_tasks.lock
.claude/scheduled_tasks.json

# NOTE: Cargo.lock and package-lock.json ARE committed (application, reproducible builds).

# Generated by `npm run setup:build`: absolute paths to this machine's CMake and libclang
# (whisper.cpp is compiled from source, ADR-PROJ-005). Machine-specific — never committed.
.cargo/

# The bundled speech model, fetched by `npm run prepare:model` into the bundle-resources dir for a
# release build (ADR-PROJ-006). ~147 MB of verifiable data — never committed; the build fetches it.
src-tauri/resources/models/*.bin
